 #include "hwgui.ch"
 
 FUNCTION Main()

 LOCAL oMainWindow, oMainIcon
 LOCAL coriginp, olabel1, olabel2
 
 
* Display the origin path, so that you are shure,
* that your program is started in the desired directory.
 
coriginp := hb_argV( 0 ) 

* Load icon
#ifdef __PLATFORM__WINDOWS
  oMainIcon := HIcon():AddFile ( "hwgui_256x256.ico" )  && 256x256 (max size for Windows)
#else
 PUBLIC cResourcehwgui
  LOAD_HEX_RES() 
  oMainIcon := HIcon():AddString( "hwgui" , cResourcehwgui ) 
// oMainIcon := HIcon():AddFile ( "hwgui_128x128.ico" )  
#endif 

 
   INIT WINDOW oMainWindow ;
      MAIN ;
      TITLE "Iconfication Example" ;
      ICON oMainIcon ;
      AT 200,0 ;
      SIZE 400,250
      

    @ 20,10 SAY olabel1 CAPTION "Origin path is:" SIZE 120,30
    @ 20,50 SAY olabel2 CAPTION ALLTRIM(coriginp)  SIZE 380,30

   @ 100,100 BUTTON "Close"  ;
      SIZE 80,30  ;
      ON CLICK {||hwg_EndWindow()}
 
   ACTIVATE WINDOW oMainWindow CENTER

RETURN NIL



#ifndef __PLATFORM__WINDOWS

FUNCTION LOAD_HEX_RES()
* Creates the ico bitmap from Hex dump.

